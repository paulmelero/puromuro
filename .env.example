TURNSTILE_SECRET_KEY=III...
TURNSTILE_SITE_KEY=SSS...
RESEND_API_KEY=AAA...

# Nuxt Studio — GitHub OAuth App credentials
# (Create the OAuth App at https://github.com/settings/developers)
#
# Local dev: copy to `.env` and fill in. In production these must be set as
# Cloudflare Worker secrets (dashboard or `wrangler secret put`), NOT here.
#
# IMPORTANT (nuxt-studio v1.7.0): use these exact STUDIO_* names. The /_studio
# login page checks process.env.STUDIO_GITHUB_CLIENT_ID directly, so the
# NUXT_STUDIO_AUTH_GITHUB_* names shown in the online docs (a newer, unreleased
# build) do NOT work on their own with v1.7.0 — /_studio returns 404.
STUDIO_GITHUB_CLIENT_ID=AAA...
STUDIO_GITHUB_CLIENT_SECRET=CCC...
